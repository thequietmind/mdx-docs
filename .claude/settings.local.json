{
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep)",
      "Bash(yarn lint)",
      "Bash(yarn test:*)",
      "Bash(npm test:*)",
      "Bash(npm run test:coverage:*)",
      "Bash(npm run coverage:*)",
      "Bash(rm:./tmp/*)",
      "Bash(rm:./coverage/*)",
      "Bash(rm:./dist/*)",
      "Bash(rm:./build/*)"
    ],
    "deny": [
      "Bash(rm:-rf /)",
      "Bash(rm:-rf ~)",
      "Bash(rm:-rf .)",
      "Bash(sudo:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git clean:*)"
    ]
  }
}
