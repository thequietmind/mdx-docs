{
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep)",
      "Bash(yarn lint)",
      "Bash(yarn test:*)",
      "Bash(npm test:*)",
      "Bash(npm run test:coverage:*)",
      "Bash(npm run coverage:*)"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(rm:-rf /)",
      "Bash(rm:-rf ~)",
      "Bash(rm:-rf .)",
      "Bash(yarn add:*)",
      "Bash(yarn remove:*)",
      "Bash(npm install:*)",
      "Bash(npm uninstall:*)",
      "Bash(sudo:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git clean:*)"
    ]
  }
}