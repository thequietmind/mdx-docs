{
  "name": "@quietmind/mdx-docs",
  "version": "1.5.0",
  "type": "module",
  "homepage": "https://mdxdocs.com",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./index.css": "./dist/index.css",
    "./server": {
      "import": "./dist/server.js"
    },
    "./vite": "./src/vite.config.helper.js"
  },
  "files": [
    "dist",
    "src/prerenderHtml.js",
    "src/vite.config.helper.js"
  ],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --config vite.lib.config.js",
    "lint": "eslint .",
    "prepack": "yarn build:lib",
    "preview": "vite preview",
    "release": "npm publish --registry https://registry.npmjs.org",
    "serve": "vite preview --host",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:average": "yarn test:coverage && node scripts/coverage-average.js",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^5.0.0"
  },
  "peerDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mdx-js/react": "^3.1.0",
    "@mdx-js/rollup": "^3.1.0",
    "@mui/icons-material": "^7.1.2",
    "@mui/material": "^7.1.2",
    "@vitejs/plugin-react": "^6.0.2",
    "prism-react-renderer": "^2.4.1",
    "prismjs": "^1.30.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "vite": "^8.1.3"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@eslint/js": "^10.0.1",
    "@mdx-js/react": "^3.1.0",
    "@mdx-js/rollup": "^3.1.0",
    "@mui/icons-material": "^7.1.2",
    "@mui/material": "^7.1.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "eslint": "^9.25.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "identity-obj-proxy": "^3.0.0",
    "jsdom": "^29.1.1",
    "prism-react-renderer": "^2.4.1",
    "prismjs": "^1.30.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "remark-gfm": "^4.0.1",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
